<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ToDo_Application"
             x:Class="ToDo_Application.CompletedPage"
             Title="Completed">

    <CollectionView ItemsSource="{Binding CompletedTasks}" 
                    SelectionMode="Single"
                    SelectionChanged="OnSelectionChanged"
                    Margin="10">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="local:ToDoClass">
                <Grid ColumnDefinitions="*, Auto" Padding="15">
                    <Label Grid.Column="0" Text="{Binding item_name}" FontSize="18" TextColor="Gray" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="🗑️" BackgroundColor="Transparent" Clicked="OnDeleteClicked" CommandParameter="{Binding .}" />
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>