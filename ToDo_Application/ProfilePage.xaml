<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDo_Application.ProfilePage"
             Title="Profile">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
        <Border Stroke="Transparent" HeightRequest="200" WidthRequest="200" HorizontalOptions="Center">
            <Border.StrokeShape><RoundRectangle CornerRadius="100"/></Border.StrokeShape>
            <Image Source="dotnet_bot.png" Aspect="AspectFill" BackgroundColor="LightGray" />
        </Border>
        <Label Text="User Profile" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
        <Button Text="Sign out" Clicked="OnSignOutClicked" BackgroundColor="Gray" TextColor="White" WidthRequest="200" HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>