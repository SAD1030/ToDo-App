<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ToDo_Application"
             x:Class="ToDo_Application.ToDoPage"
             Title="ToDo">

    <Grid RowDefinitions="Auto, *">
        <Button Grid.Row="0" Text="+" Clicked="OnAddButtonClicked" 
                HorizontalOptions="End" WidthRequest="50" HeightRequest="50" 
                Margin="10" BackgroundColor="#A799E6" TextColor="White" CornerRadius="25" />

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding IncompleteTasks}" 
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged"
                        Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:ToDoClass">
                    <Grid Padding="15">
                        <Label Text="{Binding item_name}" FontSize="18" TextColor="Black" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>